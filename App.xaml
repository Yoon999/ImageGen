<Application x:Class="ImageGen.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ImageGen"
             StartupUri="Views/MainWindow.xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#111827" />
            <SolidColorBrush x:Key="AppSurfaceBrush" Color="#172033" />
            <SolidColorBrush x:Key="AppSurfaceAltBrush" Color="#1F2937" />
            <SolidColorBrush x:Key="AppSurfaceRaisedBrush" Color="#263449" />
            <SolidColorBrush x:Key="AppBorderBrush" Color="#374151" />
            <SolidColorBrush x:Key="AppTextBrush" Color="#F9FAFB" />
            <SolidColorBrush x:Key="AppMutedTextBrush" Color="#A7B0C0" />
            <SolidColorBrush x:Key="AppAccentBrush" Color="#38BDF8" />
            <SolidColorBrush x:Key="AppAccentSoftBrush" Color="#1E3A5F" />
            <SolidColorBrush x:Key="AppSuccessBrush" Color="#2E7D5B" />
            <SolidColorBrush x:Key="AppWarningBrush" Color="#9A6B24" />
            <SolidColorBrush x:Key="AppDangerBrush" Color="#8F3131" />
            <SolidColorBrush x:Key="NodePortFlowBrush" Color="#9CA3AF" />
            <SolidColorBrush x:Key="NodePortBaseBrush" Color="#7DD3A7" />
            <SolidColorBrush x:Key="NodePortCharacterBrush" Color="#F9A8A8" />

            <Thickness x:Key="AppControlMargin">0,0,8,8</Thickness>
            <CornerRadius x:Key="AppCornerRadius">8</CornerRadius>

            <Style x:Key="PanelBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="{StaticResource AppCornerRadius}" />
                <Setter Property="Padding" Value="8" />
            </Style>

            <Style x:Key="ToolbarButtonStyle" TargetType="Button">
                <Setter Property="MinHeight" Value="30" />
                <Setter Property="Padding" Value="8,3" />
                <Setter Property="Margin" Value="0,0,6,0" />
                <Setter Property="Background" Value="{StaticResource AppSurfaceRaisedBrush}" />
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <Style x:Key="IconButtonStyle"
                   TargetType="{x:Type ui:Button}"
                   BasedOn="{StaticResource {x:Type ui:Button}}">
                <Setter Property="Width" Value="32" />
                <Setter Property="MinWidth" Value="32" />
                <Setter Property="Height" Value="30" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0,0,6,0" />
                <Setter Property="Background" Value="{StaticResource AppSurfaceRaisedBrush}" />
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <Style x:Key="ChipButtonStyle" TargetType="Button">
                <Setter Property="MinHeight" Value="24" />
                <Setter Property="Padding" Value="7,2" />
                <Setter Property="Margin" Value="0,0,6,2" />
                <Setter Property="Background" Value="{StaticResource AppAccentSoftBrush}" />
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Focusable" Value="False" />
            </Style>

            <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource AppMutedTextBrush}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,0,0,6" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
