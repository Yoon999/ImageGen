<Window x:Class="ImageGen.Views.PresetSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ImageGen.Views"
        xmlns:models="clr-namespace:ImageGen.Models"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Select Character Preset" Height="450" Width="400"
        WindowStartupLocation="CenterOwner"
        Background="#1e1e1e" Foreground="White">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <HierarchicalDataTemplate DataType="{x:Type models:CharacterPreset}" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="2">
                <!-- 폴더 아이콘 -->
                <TextBlock Text="📁 " Foreground="#FFD700"
                           Visibility="{Binding IsFolder, Converter={StaticResource BoolToVisibilityConverter}}" />
                <!-- 파일 아이콘 -->
                <TextBlock Text="📄 " Foreground="#87CEEB"
                           Visibility="{Binding IsFolder, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}" />
                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="True" />
            <Setter Property="Foreground" Value="White"/>
            <!-- 더블 클릭 이벤트 연결 (코드 비하인드에서 처리) -->
            <EventSetter Event="MouseDoubleClick" Handler="TreeViewItem_MouseDoubleClick"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Select a preset to load:" Margin="0,0,0,10" Foreground="LightGray"/>

        <TreeView Grid.Row="1" x:Name="PresetTreeView" Background="#2d2d2d" BorderBrush="#3f3f46" BorderThickness="1"
                  SelectedItemChanged="PresetTreeView_SelectedItemChanged">
        </TreeView>

        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" x:Name="SelectedPathText" VerticalAlignment="Center" Foreground="LightGray" TextWrapping="Wrap"/>
            
            <ui:Button Grid.Column="1" x:Name="LoadButton" Content="Load" Click="LoadButton_Click" 
                       Width="80" Margin="0,0,10,0" IsEnabled="False" Appearance="Primary"/>
            <ui:Button Grid.Column="2" Content="Cancel" Click="CancelButton_Click" Width="80"/>
        </Grid>
    </Grid>
</Window>
