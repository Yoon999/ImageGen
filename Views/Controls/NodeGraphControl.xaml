<UserControl x:Class="ImageGen.Views.Controls.NodeGraphControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:ImageGen.Helpers"
             xmlns:controls="clr-namespace:ImageGen.Views.Controls"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800"
             PreviewMouseWheel="UserControl_PreviewMouseWheel"
             PreviewKeyDown="UserControl_PreviewKeyDown"
             Focusable="True">

    <UserControl.Resources>
        <helpers:ConnectionColorConverter x:Key="ConnectionColorConverter" />
        <helpers:NodeTypeToColorConverter x:Key="NodeTypeToColorConverter" />
        <helpers:NodeTypeToVisibilityConverter x:Key="NodeTypeToVisibilityConverter" />
        <helpers:NodeTypeToBooleanConverter x:Key="NodeTypeToBooleanConverter" />
        <helpers:MultiValueConverter x:Key="MultiValueConverter" />
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="NodeActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Margin" Value="0,0,4,0" />
        </Style>

        <Style x:Key="NodePortStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="Stroke" Value="{StaticResource AppTextBrush}" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Margin" Value="0,4" />
        </Style>

        <DataTemplate x:Key="NodeTemplate">
            <Border Background="{StaticResource AppSurfaceBrush}"
                    BorderBrush="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=SelectionColor}"
                    BorderThickness="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=SelectionThickness}"
                    CornerRadius="8"
                    MinWidth="180"
                    MaxWidth="280"
                    SizeChanged="Node_SizeChanged"
                    Opacity="{Binding IsBypassed, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Opacity}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="-8,0,8,0">
                        <Ellipse Style="{StaticResource NodePortStyle}"
                                 Fill="{StaticResource NodePortFlowBrush}"
                                 Visibility="{Binding Type, Converter={StaticResource NodeTypeToVisibilityConverter}, ConverterParameter=Input}"
                                 MouseLeftButtonDown="InputPort_MouseLeftButtonDown"
                                 ToolTip="Flow input. Ctrl+Click disconnects incoming links." />

                        <Ellipse Style="{StaticResource NodePortStyle}"
                                 Width="12"
                                 Height="12"
                                 Fill="{StaticResource NodePortBaseBrush}"
                                 Visibility="{Binding Type, Converter={StaticResource NodeTypeToVisibilityConverter}, ConverterParameter=BaseInput}"
                                 ToolTip="Base prompt input." />

                        <Ellipse Style="{StaticResource NodePortStyle}"
                                 Width="12"
                                 Height="12"
                                 Fill="{StaticResource NodePortCharacterBrush}"
                                 Visibility="{Binding Type, Converter={StaticResource NodeTypeToVisibilityConverter}, ConverterParameter=CharacterInput}"
                                 ToolTip="Character prompt input." />
                    </StackPanel>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{Binding Type, Converter={StaticResource NodeTypeToColorConverter}}"
                                CornerRadius="7,7,0,0"
                                Padding="8,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ui:TextBox Text="{Binding Title}"
                                            FontWeight="SemiBold"
                                            Foreground="White"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            HorizontalContentAlignment="Left"
                                            IsReadOnly="{Binding Type, Converter={StaticResource NodeTypeToBooleanConverter}, ConverterParameter=IsReadOnlyTitle}"
                                            Focusable="{Binding Type, Converter={StaticResource NodeTypeToBooleanConverter}, ConverterParameter=IsFocusable}"
                                            ToolTip="Node title" />

                                <ui:Button Grid.Column="1"
                                           Content="Collapse"
                                           Command="{Binding DataContext.ToggleCollapseCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                           Visibility="{Binding Type, Converter={StaticResource NodeTypeToVisibilityConverter}, ConverterParameter=Collapse}"
                                           CommandParameter="{Binding}"
                                           Height="22"
                                           Padding="6,0"
                                           FontSize="10"
                                           Background="Transparent"
                                           BorderThickness="0" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Background="{StaticResource AppSurfaceAltBrush}"
                                Padding="8">
                            <StackPanel>
                                <Border Background="{StaticResource AppDangerBrush}"
                                        CornerRadius="4"
                                        Padding="5,2"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,6"
                                        Visibility="{Binding IsBypassed, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="BYPASSED" Foreground="White" FontSize="10" FontWeight="Bold" />
                                </Border>

                                <StackPanel Visibility="{Binding IsCollapsed, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                                    <StackPanel Visibility="{Binding Type, Converter={StaticResource NodeTypeToVisibilityConverter}, ConverterParameter=Content}">
                                        <ui:TextBlock Text="Inputs connected via pins"
                                                      Foreground="{StaticResource AppMutedTextBrush}"
                                                      FontSize="10"
                                                      FontStyle="Italic"
                                                      HorizontalAlignment="Center" />
                                    </StackPanel>

                                    <StackPanel Visibility="{Binding Type, Converter={StaticResource NodeTypeToVisibilityConverter}, ConverterParameter=BaseContent}">
                                        <ui:TextBlock Text="Positive Prompt" Style="{StaticResource SectionLabelStyle}" />
                                        <ui:TextBox Text="{Binding BasePrompt}"
                                                    Margin="0,0,0,6"
                                                    MinHeight="44"
                                                    MaxHeight="120"
                                                    TextAlignment="Left"
                                                    TextWrapping="Wrap"
                                                    AcceptsReturn="True"
                                                    VerticalScrollBarVisibility="Auto"
                                                    ClearButtonEnabled="False"
                                                    TextChanged="PromptBox_OnTextChanged"
                                                    GotFocus="PromptBox_GotFocus"
                                                    PreviewKeyDown="PromptBox_PreviewKeyDown" />

                                        <ui:TextBlock Text="Negative Prompt" Style="{StaticResource SectionLabelStyle}" />
                                        <ui:TextBox Text="{Binding NegativePrompt}"
                                                    MinHeight="44"
                                                    MaxHeight="120"
                                                    TextAlignment="Left"
                                                    TextWrapping="Wrap"
                                                    AcceptsReturn="True"
                                                    VerticalScrollBarVisibility="Auto"
                                                    ClearButtonEnabled="False"
                                                    TextChanged="PromptBox_OnTextChanged"
                                                    GotFocus="PromptBox_GotFocus"
                                                    PreviewKeyDown="PromptBox_PreviewKeyDown" />
                                    </StackPanel>

                                    <StackPanel Visibility="{Binding Type, Converter={StaticResource NodeTypeToVisibilityConverter}, ConverterParameter=CharacterContent}">
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Button Grid.Column="0"
                                                    Content="Load"
                                                    Command="{Binding DataContext.OpenPresetWindowCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource NodeActionButtonStyle}"
                                                    ToolTip="Load preset" />

                                            <Button Grid.Column="1"
                                                    Content="Save"
                                                    Command="{Binding DataContext.OpenSavePresetWindowCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource NodeActionButtonStyle}"
                                                    ToolTip="Save as new preset" />

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding PresetNameDisplay}"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource AppMutedTextBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding PresetNameDisplay}" />
                                        </Grid>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,6">
                                            <Button Content="Clear"
                                                    Command="{Binding DataContext.ClearCharacterPresetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource NodeActionButtonStyle}"
                                                    ToolTip="Clear selected preset" />

                                            <Button Content="Update"
                                                    Command="{Binding DataContext.UpdateCharacterPresetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource NodeActionButtonStyle}"
                                                    ToolTip="Update selected preset" />
                                        </StackPanel>

                                        <ui:TextBlock Text="Positive Prompt" Style="{StaticResource SectionLabelStyle}" />
                                        <ui:TextBox Text="{Binding BasePrompt}"
                                                    Margin="0,0,0,6"
                                                    MinHeight="44"
                                                    MaxHeight="120"
                                                    TextAlignment="Left"
                                                    TextWrapping="Wrap"
                                                    AcceptsReturn="True"
                                                    VerticalScrollBarVisibility="Auto"
                                                    ClearButtonEnabled="False"
                                                    TextChanged="PromptBox_OnTextChanged"
                                                    GotFocus="PromptBox_GotFocus"
                                                    PreviewKeyDown="PromptBox_PreviewKeyDown" />

                                        <ui:TextBlock Text="Negative Prompt" Style="{StaticResource SectionLabelStyle}" />
                                        <ui:TextBox Text="{Binding NegativePrompt}"
                                                    Margin="0,0,0,6"
                                                    MinHeight="44"
                                                    MaxHeight="120"
                                                    TextAlignment="Left"
                                                    TextWrapping="Wrap"
                                                    AcceptsReturn="True"
                                                    VerticalScrollBarVisibility="Auto"
                                                    ClearButtonEnabled="False"
                                                    TextChanged="PromptBox_OnTextChanged"
                                                    GotFocus="PromptBox_GotFocus"
                                                    PreviewKeyDown="PromptBox_PreviewKeyDown" />

                                        <Grid Margin="0,2,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="124" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <controls:CharacterPositionGrid Grid.Column="0"
                                                                            XValue="{Binding CharX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                            YValue="{Binding CharY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                            Width="120"
                                                                            Height="120" />
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <TextBlock Text="Center" Foreground="{StaticResource AppMutedTextBrush}" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,5" />
                                                <DockPanel Margin="0,0,0,5">
                                                    <TextBlock Text="X" Width="16" Foreground="{StaticResource AppMutedTextBrush}" FontSize="10" VerticalAlignment="Center" />
                                                    <ui:TextBox Text="{Binding CharX, StringFormat=N1, UpdateSourceTrigger=PropertyChanged}" />
                                                </DockPanel>
                                                <DockPanel>
                                                    <TextBlock Text="Y" Width="16" Foreground="{StaticResource AppMutedTextBrush}" FontSize="10" VerticalAlignment="Center" />
                                                    <ui:TextBox Text="{Binding CharY, StringFormat=N1, UpdateSourceTrigger=PropertyChanged}" />
                                                </DockPanel>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel Visibility="{Binding Type, Converter={StaticResource NodeTypeToVisibilityConverter}, ConverterParameter=BaseConcatContent}">
                                        <ui:TextBlock Text="Input Order" Style="{StaticResource SectionLabelStyle}" />
                                        <ItemsControl ItemsSource="{Binding InputNodes}" Margin="0,0,0,8">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Title}"
                                                                   Foreground="{StaticResource AppTextBrush}"
                                                                   FontSize="10"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                            <Button Content="Up"
                                                                    Style="{StaticResource NodeActionButtonStyle}"
                                                                    Command="{Binding DataContext.MoveInputUpCommand, RelativeSource={RelativeSource AncestorType=ItemsControl, AncestorLevel=2}}">
                                                                <Button.CommandParameter>
                                                                    <MultiBinding Converter="{StaticResource MultiValueConverter}">
                                                                        <Binding Path="." />
                                                                        <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                                    </MultiBinding>
                                                                </Button.CommandParameter>
                                                            </Button>
                                                            <Button Content="Down"
                                                                    Style="{StaticResource NodeActionButtonStyle}"
                                                                    Command="{Binding DataContext.MoveInputDownCommand, RelativeSource={RelativeSource AncestorType=ItemsControl, AncestorLevel=2}}">
                                                                <Button.CommandParameter>
                                                                    <MultiBinding Converter="{StaticResource MultiValueConverter}">
                                                                        <Binding Path="." />
                                                                        <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                                    </MultiBinding>
                                                                </Button.CommandParameter>
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <ui:TextBlock Text="Concatenates inputs from Base nodes"
                                                      Foreground="{StaticResource AppMutedTextBrush}"
                                                      FontSize="10"
                                                      FontStyle="Italic"
                                                      HorizontalAlignment="Center" />
                                    </StackPanel>

                                    <StackPanel Visibility="{Binding Type, Converter={StaticResource NodeTypeToVisibilityConverter}, ConverterParameter=GraphContent}">
                                        <ui:TextBlock Text="Graph File Path" Style="{StaticResource SectionLabelStyle}" />
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ui:TextBox Text="{Binding BasePrompt}" IsReadOnly="True" ToolTip="{Binding BasePrompt}" />
                                            <Button Grid.Column="1"
                                                    Content="Browse"
                                                    Command="{Binding DataContext.SelectGraphFileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource NodeActionButtonStyle}"
                                                    Margin="6,0,0,0" />
                                        </Grid>
                                        <ui:TextBlock Text="Executes the selected graph"
                                                      Foreground="{StaticResource AppMutedTextBrush}"
                                                      FontSize="10"
                                                      FontStyle="Italic"
                                                      HorizontalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2"
                                Background="{StaticResource AppSurfaceBrush}"
                                CornerRadius="0,0,7,7"
                                Padding="8,6">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Run"
                                        Command="{Binding DataContext.GenerateChainCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource NodeActionButtonStyle}"
                                        Background="{StaticResource AppSuccessBrush}"
                                        Visibility="{Binding Type, Converter={StaticResource NodeTypeToVisibilityConverter}, ConverterParameter=Content}" />

                                <Button Content="Bypass"
                                        Command="{Binding DataContext.ToggleBypassCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource NodeActionButtonStyle}"
                                        Background="{StaticResource AppWarningBrush}" />

                                <Button Content="Duplicate"
                                        Command="{Binding DataContext.DuplicateNodeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource NodeActionButtonStyle}"
                                        Visibility="{Binding Type, Converter={StaticResource NodeTypeToVisibilityConverter}, ConverterParameter=Delete}" />

                                <Button Content="Delete"
                                        Command="{Binding DataContext.DeleteNodeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource NodeActionButtonStyle}"
                                        Background="{StaticResource AppDangerBrush}"
                                        Margin="0"
                                        Visibility="{Binding Type, Converter={StaticResource NodeTypeToVisibilityConverter}, ConverterParameter=Delete}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <ui:Button Grid.Column="2"
                               Width="18"
                               Height="18"
                               Margin="8,0,-9,0"
                               VerticalAlignment="Center"
                               Command="{Binding DataContext.StartConnectionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                               CommandParameter="{Binding}"
                               ToolTip="Connect to next node. Ctrl+Click disconnects outgoing links."
                               Visibility="{Binding Type, Converter={StaticResource NodeTypeToVisibilityConverter}, ConverterParameter=Output}"
                               PreviewMouseLeftButtonDown="OutputPort_MouseLeftButtonDown">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Ellipse Fill="{Binding NextNode, Converter={StaticResource ConnectionColorConverter}}"
                                         Stroke="{StaticResource AppTextBrush}"
                                         StrokeThickness="1.5" />
                            </ControlTemplate>
                        </Button.Template>
                    </ui:Button>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}" Padding="10" Margin="0,0,0,10">
            <DockPanel LastChildFill="True">
                <WrapPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="File" Style="{StaticResource SectionLabelStyle}" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <Button Content="Save Graph" Command="{Binding SaveGraphCommand}" Style="{StaticResource ToolbarButtonStyle}" />
                    <Button Content="Load Graph" Command="{Binding LoadGraphCommand}" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,14,0" />

                    <TextBlock Text="Add" Style="{StaticResource SectionLabelStyle}" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <Button Content="Normal" Command="{Binding AddNodeCommand}" Style="{StaticResource ToolbarButtonStyle}" />
                    <Button Content="Base" Command="{Binding AddBaseNodeCommand}" Style="{StaticResource ToolbarButtonStyle}" />
                    <Button Content="Concat" Command="{Binding AddBaseConcatNodeCommand}" Style="{StaticResource ToolbarButtonStyle}" />
                    <Button Content="Character" Command="{Binding AddCharacterNodeCommand}" Style="{StaticResource ToolbarButtonStyle}" />
                    <Button Content="Graph" Command="{Binding AddGraphNodeCommand}" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,14,0" />

                    <TextBlock Text="Run" Style="{StaticResource SectionLabelStyle}" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <Button Content="Run All"
                            Command="{Binding GenerateChainCommand}"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Background="{StaticResource AppSuccessBrush}"
                            Margin="0,0,14,0" />

                    <TextBlock Text="View" Style="{StaticResource SectionLabelStyle}" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <Button Content="-" Command="{Binding ZoomOutCommand}" Style="{StaticResource ToolbarButtonStyle}" Width="32" />
                    <TextBlock Text="{Binding ZoomScale, StringFormat=P0}"
                               VerticalAlignment="Center"
                               Width="48"
                               TextAlignment="Center"
                               Foreground="{StaticResource AppTextBrush}" />
                    <Button Content="+" Command="{Binding ZoomInCommand}" Style="{StaticResource ToolbarButtonStyle}" Width="32" />
                    <Button Content="Reset" Command="{Binding ResetZoomCommand}" Style="{StaticResource ToolbarButtonStyle}" />
                    <Button Content="Go Begin" Command="{Binding GoToBeginNodeCommand}" Style="{StaticResource ToolbarButtonStyle}" Margin="0" />
                </WrapPanel>

                <Border Background="{StaticResource AppAccentSoftBrush}"
                        BorderBrush="{StaticResource AppAccentBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8,4"
                        HorizontalAlignment="Right"
                        Visibility="{Binding IsConnecting, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="Click a target node to connect. Click empty canvas to cancel."
                               Foreground="{StaticResource AppTextBrush}"
                               FontSize="12" />
                </Border>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource PanelBorderStyle}" Padding="0" ClipToBounds="True">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" PanningMode="Both">
                <Grid Width="5000" Height="5000" Background="#10151F">
                    <Grid.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding ZoomScale}" ScaleY="{Binding ZoomScale}" />
                    </Grid.LayoutTransform>

                    <ItemsControl ItemsSource="{Binding Connections}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas IsHitTestVisible="False" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Line X1="{Binding X1}"
                                      Y1="{Binding Y1}"
                                      X2="{Binding X2}"
                                      Y2="{Binding Y2}"
                                      Stroke="{StaticResource AppAccentBrush}"
                                      StrokeThickness="2.4"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Canvas IsHitTestVisible="False" Visibility="{Binding IsConnecting, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Line X1="{Binding TempX1}"
                              Y1="{Binding TempY1}"
                              X2="{Binding TempX2}"
                              Y2="{Binding TempY2}"
                              Stroke="{StaticResource AppAccentBrush}"
                              StrokeThickness="3"
                              StrokeDashArray="5 3" />
                    </Canvas>

                    <ItemsControl ItemsSource="{Binding Nodes}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas Background="Transparent"
                                        MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                                        MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                                        MouseMove="Canvas_MouseMove" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding UiX, Mode=TwoWay}" />
                                <Setter Property="Canvas.Top" Value="{Binding UiY, Mode=TwoWay}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ContentControl Content="{Binding}"
                                                ContentTemplate="{StaticResource NodeTemplate}"
                                                MouseLeftButtonDown="Node_MouseLeftButtonDown"
                                                MouseLeftButtonUp="Node_MouseLeftButtonUp" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Canvas IsHitTestVisible="False" Visibility="{Binding IsSelecting, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Rectangle Canvas.Left="{Binding SelectionX}"
                                   Canvas.Top="{Binding SelectionY}"
                                   Width="{Binding SelectionWidth}"
                                   Height="{Binding SelectionHeight}"
                                   Stroke="{StaticResource AppAccentBrush}"
                                   StrokeThickness="1.4"
                                   Fill="#3338BDF8" />
                    </Canvas>
                </Grid>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" Background="{StaticResource AppSurfaceBrush}" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,10,0,0">
            <TextBlock Foreground="{StaticResource AppMutedTextBrush}"
                       FontSize="12"
                       Text="Shortcuts: Ctrl+Shift+Wheel zoom, Ctrl+C/V copy/paste, Delete remove, Ctrl+B bypass, Ctrl+Home go to Begin. Ctrl+drag on canvas selects nodes." />
        </Border>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" MaxHeight="78" Margin="0,10,0,0">
            <ItemsControl ItemsSource="{Binding TagSuggestions}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding Tag}"
                                Style="{StaticResource ChipButtonStyle}"
                                Click="TagSuggestionButton_Click"
                                Tag="{Binding}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
