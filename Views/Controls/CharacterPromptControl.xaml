<UserControl x:Class="ImageGen.Views.Controls.CharacterPromptControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:ImageGen.Helpers"
             xmlns:controls="clr-namespace:ImageGen.Views.Controls"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="260"
             d:DesignWidth="400"
             Background="Transparent">

    <UserControl.Resources>
        <helpers:NullToBoolConverter x:Key="NullToBoolConverter" />
    </UserControl.Resources>

    <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,6" Padding="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="Load"
                                Command="{Binding OpenPresetWindowCommand}"
                                Style="{StaticResource ToolbarButtonStyle}"
                                ToolTip="Load preset" />

                        <Button Grid.Column="1"
                                Content="Save"
                                Command="{Binding OpenSavePresetWindowCommand}"
                                Style="{StaticResource ToolbarButtonStyle}"
                                ToolTip="Save as new preset" />

                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Clear"
                                    Command="{Binding ClearPresetCommand}"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    ToolTip="Clear selected preset" />

                            <Button Content="Update"
                                    Command="{Binding UpdatePresetCommand}"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    ToolTip="Update selected preset" />

                            <Button Content="Delete"
                                    Command="{Binding DeletePresetCommand}"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Background="{StaticResource AppDangerBrush}"
                                    Margin="0"
                                    ToolTip="Delete selected preset" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{Binding SelectedPresetDisplay}"
                               Foreground="{StaticResource AppMutedTextBrush}"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding SelectedPresetDisplay}" />
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Remove"
                        Command="{Binding DataContext.RemoveCharacterCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                        CommandParameter="{Binding}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Background="{StaticResource AppDangerBrush}"
                        Margin="8,0,0,0"
                        VerticalAlignment="Top"
                        ToolTip="Remove character prompt from layout" />
            </Grid>

            <TabControl Grid.Row="1" Height="126" Margin="0,0,0,8">
                <TabItem Header="Positive">
                    <ui:TextBox Text="{Binding Prompt, UpdateSourceTrigger=PropertyChanged}"
                                TextAlignment="Left"
                                TextWrapping="Wrap"
                                AcceptsReturn="True"
                                VerticalScrollBarVisibility="Auto"
                                ClearButtonEnabled="False"
                                TextChanged="PromptBox_OnTextChanged"
                                GotFocus="PromptBox_GotFocus"
                                PreviewKeyDown="PromptBox_PreviewKeyDown" />
                </TabItem>
                <TabItem Header="Negative">
                    <ui:TextBox Text="{Binding NegativePrompt, UpdateSourceTrigger=PropertyChanged}"
                                TextAlignment="Left"
                                TextWrapping="Wrap"
                                AcceptsReturn="True"
                                VerticalScrollBarVisibility="Auto"
                                ClearButtonEnabled="False"
                                TextChanged="PromptBox_OnTextChanged"
                                GotFocus="PromptBox_GotFocus"
                                PreviewKeyDown="PromptBox_PreviewKeyDown" />
                </TabItem>
            </TabControl>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <controls:CharacterPositionGrid Grid.Column="0"
                                                XValue="{Binding X, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                YValue="{Binding Y, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Width="140"
                                                Height="140" />

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="Character Center" Foreground="{StaticResource AppMutedTextBrush}" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <DockPanel Margin="0,0,0,6">
                        <ui:TextBlock Text="X" Width="20" Foreground="{StaticResource AppMutedTextBrush}" VerticalAlignment="Center" />
                        <ui:TextBox Text="{Binding X, StringFormat=N1, UpdateSourceTrigger=PropertyChanged}" Width="64" />
                    </DockPanel>
                    <DockPanel>
                        <ui:TextBlock Text="Y" Width="20" Foreground="{StaticResource AppMutedTextBrush}" VerticalAlignment="Center" />
                        <ui:TextBox Text="{Binding Y, StringFormat=N1, UpdateSourceTrigger=PropertyChanged}" Width="64" />
                    </DockPanel>
                    <TextBlock Text="Click or drag on the grid. Values snap to 0.1."
                               Foreground="{StaticResource AppMutedTextBrush}"
                               TextWrapping="Wrap"
                               FontSize="11"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
